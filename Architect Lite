    <script>
        lucide.createIcons();

        function copyToClipboard() {
            const rawCode = `// ==UserScript==
// @name          Architect Lite 1.2 - Full Fix
// @namespace     http://tampermonkey.net/
// @version       1.2.3
// @description   Persistent Lens with Lucide Icons, Chat History, Model Swapping, and UI fix for long text.
// @author        Your Name
// @match         *://*/*
// @run-at        document-end
// ==/UserScript==

(async () => {
    const API = "https://openrouter.ai/api/v1/chat/completions";
    let KEY = localStorage.getItem("ai_helper_api_key") || "";
    let SELECTED_MODEL = "openai/gpt-4o-mini";
    let chatHistory = [];
    let busy = false;
    let isHidden = false;
    let activeStream = null;

    const loadLucide = () => {
        const script = document.createElement('script');
        script.src = "https://unpkg.com/lucide@latest";
        script.onload = () => lucide.createIcons();
        document.head.appendChild(script);
    };

    const toggleUI = () => {
        const panel = document.getElementById("ai-panel");
        if (!panel) return;
        isHidden = !isHidden;
        panel.style.display = isHidden ? "none" : "flex";
    };

    window.addEventListener("keydown", (e) => {
        if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
        if (e.key === "/") { e.preventDefault(); toggleUI(); }
    });

    const getStream = async () => {
        if (activeStream && activeStream.active) return activeStream;
        try {
            activeStream = await navigator.mediaDevices.getDisplayMedia({ 
                video: { displaySurface: "browser" },
                selfBrowserSurface: "include" 
            });
            activeStream.getVideoTracks()[0].onended = () => {
                activeStream = null;
                const dot = document.getElementById("ai-status-dot");
                if (dot) dot.style.background = "#475569";
            };
            return activeStream;
        } catch (e) { return null; }
    };

    const startCapture = async () => {
        if (busy) return;
        const stream = await getStream();
        if (!stream) return;
        const video = document.createElement('video');
        video.srcObject = stream;
        await video.play();
        setTimeout(() => {
            const canvas = document.createElement('canvas');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            createSelector(canvas);
            video.pause();
            video.srcObject = null;
        }, 150);
    };

    const createSelector = (fullCanvas) => {
        const overlay = document.createElement('div');
        overlay.style = "position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.4);z-index:2147483647;cursor:crosshair;";
        const selector = document.createElement('div');
        selector.style = "position:absolute;border:2px solid #818cf8;background:rgba(99, 102, 241, 0.1);";
        overlay.appendChild(selector);
        document.body.appendChild(overlay);
        let startX, startY;
        overlay.onmousedown = (e) => { startX = e.clientX; startY = e.clientY; };
        overlay.onmousemove = (e) => {
            if (startX === undefined) return;
            selector.style.width = Math.abs(e.clientX - startX) + 'px';
            selector.style.height = Math.abs(e.clientY - startY) + 'px';
            selector.style.left = Math.min(e.clientX, startX) + 'px';
            selector.style.top = Math.min(e.clientY, startY) + 'px';
        };
        overlay.onmouseup = () => {
            const rect = selector.getBoundingClientRect();
            document.body.removeChild(overlay);
            const scaleX = fullCanvas.width / window.innerWidth;
            const scaleY = fullCanvas.height / window.innerHeight;
            const crop = document.createElement('canvas');
            crop.width = rect.width * scaleX; 
            crop.height = rect.height * scaleY;
            crop.getContext('2d').drawImage(fullCanvas, rect.left * scaleX, rect.top * scaleY, rect.width * scaleX, rect.height * scaleY, 0, 0, crop.width, crop.height);
            askAI(null, crop.toDataURL('image/jpeg', 0.9).split(',')[1]);
        };
    };

    const askAI = async (textInput = null, base64 = null) => {
        const output = document.getElementById("ai-answer");
        const status = document.getElementById("ai-status-dot");
        if (!KEY) {
            KEY = prompt("Enter OpenRouter API key:");
            localStorage.setItem("ai_helper_api_key", (KEY || "").trim());
        }
        busy = true;
        status.style.background = "#fbbf24";
        if (base64) {
            output.innerHTML = '<span style="color:#94a3b8;">Processing Scan...</span>';
            chatHistory = [{ role: "system", content: "Expert tutor. OCR and solve. Use MathJax: \\\\\\\\( ... \\\\\\\\) for inline, \\\\\\\\\\\\[ ... \\\\\\\\\\\\] for blocks." }];
            chatHistory.push({ role: "user", content: [
                { type: "text", text: "Analyze this image:" },
                { type: "image_url", image_url: { url: \`data:image/jpeg;base64,\${base64}\` } }
            ]});
        } else if (textInput) {
            chatHistory.push({ role: "user", content: textInput });
        }
        try {
            const response = await fetch(API, {
                method: "POST",
                headers: { "Authorization": \`Bearer \${KEY}\`, "Content-Type": "application/json" },
                body: JSON.stringify({ model: SELECTED_MODEL, messages: chatHistory })
            });
            const data = await response.json();
            const reply = data.choices?.[0]?.message?.content || "No response received.";
            chatHistory.push({ role: "assistant", content: reply });
            output.innerHTML = chatHistory.filter(m => m.role !== 'system').map(m => \`
                <div style="margin-bottom:12px; border-left: 2px solid \${m.role === 'user' ? '#818cf8' : '#334155'}; padding-left: 8px;">
                    <div style="font-size: 10px; color: #64748b; margin-bottom: 2px; font-weight:bold;">\${m.role.toUpperCase()}</div>
                    <div style="word-wrap: break-word;">\${(typeof m.content === 'string' ? m.content : "[Image Data]").replace(/\\\\n/g, '<br>')}</div>
                </div>
            \`).join('');
            if (window.MathJax) window.MathJax.typesetPromise([output]);
            status.style.background = "#6366f1";
            output.scrollTop = output.scrollHeight;
        } catch (e) { output.innerHTML += "<br><span style='color:#f87171;'>API Error.</span>"; }
        busy = false;
    };

    const makeUI = () => {
        const style = document.createElement("style");
        style.textContent = \`
            #ai-panel { 
                position: fixed; bottom: 20px; right: 20px; width: 340px; height: 400px;
                background: #0f111a; color: #fff; border-radius: 16px; padding: 14px; 
                font-family: ui-sans-serif, system-ui, sans-serif; z-index: 2147483646; 
                box-shadow: 0 20px 50px rgba(0,0,0,0.6); border: 1px solid #1e293b; 
                display: flex; flex-direction: column; gap: 10px; overflow: hidden;
            }
            #ai-header { flex-shrink: 0; display: flex; justify-content: space-between; align-items: center; font-size: 10px; color: #94a3b8; font-weight: 800; letter-spacing: 0.5px; }
            #ai-status-dot { width: 8px; height: 8px; background: #6366f1; border-radius: 50%; box-shadow: 0 0 8px #6366f1; transition: background 0.3s; }
            #ai-answer { flex: 1; min-height: 0; overflow-y: auto; font-size: 13px; line-height: 1.5; color: #e2e8f0; padding-right: 8px; scroll-behavior: smooth;}
            #ai-answer::-webkit-scrollbar { width: 4px; }
            #ai-answer::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
            .tool-row { flex-shrink: 0; display: flex; gap: 6px; }
            .tool-btn { background: #1e293b; color: #e2e8f0; border: 1px solid #334155; padding: 8px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
            .primary-btn { background: #6366f1; border: none; flex: 1; font-weight: 600; color: white; }
            #ai-input { background: #1e293b; border: 1px solid #334155; color: #fff; padding: 10px; border-radius: 8px; font-size: 13px; outline: none; width: 100%; box-sizing: border-box; }
            select { background: transparent; color: #64748b; border: none; font-size: 10px; outline: none; cursor: pointer; font-weight: bold; }
        \`;
        document.head.appendChild(style);
        const panel = document.createElement("div");
        panel.id = "ai-panel";
        panel.innerHTML = \`
            <div id="ai-header">
                <div style="display:flex;align-items:center;gap:6px;"><div id="ai-status-dot"></div> ARCHITECT LITE 1.2</div>
                <div style="display:flex; gap:8px; align-items:center;">
                    <select id="model-select">
                        <option value="openai/gpt-4o-mini">GPT-4o Mini</option>
                        <option value="anthropic/claude-3.5-sonnet">Claude 3.5</option>
                        <option value="google/gemini-flash-1.5">Gemini 1.5</option>
                    </select>
                    <div id="ai-close" style="cursor:pointer;"><i data-lucide="x" style="width:14px;"></i></div>
                </div>
            </div>
            <div id="ai-answer">Session started. Press <b>/</b> to toggle.</div>
            <div class="tool-row">
                <button id="lens-scan" class="tool-btn primary-btn"><i data-lucide="camera" style="width:14px; margin-right:6px;"></i> SCAN</button>
                <button id="copy-btn" class="tool-btn"><i data-lucide="copy" style="width:14px;"></i></button>
                <button id="clear-chat" class="tool-btn"><i data-lucide="trash-2" style="width:14px;"></i></button>
            </div>
            <input type="text" id="ai-input" placeholder="Type a message..." />
        \`;
        document.body.appendChild(panel);
        document.getElementById("lens-scan").onclick = startCapture;
        document.getElementById("ai-close").onclick = toggleUI;
        document.getElementById("model-select").onchange = (e) => SELECTED_MODEL = e.target.value;
        document.getElementById("clear-chat").onclick = () => { chatHistory = []; document.getElementById("ai-answer").innerHTML = "Memory cleared."; };
        document.getElementById("copy-btn").onclick = () => {
            const lastMsg = chatHistory.filter(m => m.role === 'assistant').pop()?.content || "";
            if (lastMsg) navigator.clipboard.writeText(lastMsg);
        };
        document.getElementById("ai-input").onkeydown = (e) => {
            if (e.key === "Enter" && e.target.value.trim()) {
                askAI(e.target.value.trim());
                e.target.value = "";
            }
        };
        const mathjax = document.createElement('script');
        mathjax.src = "https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js";
        document.head.appendChild(mathjax);
        loadLucide();
    };
    makeUI();
})();`;

            navigator.clipboard.writeText(rawCode).then(() => {
                const btnText = document.getElementById('btnText');
                const btnIcon = document.getElementById('btnIcon');
                const btn = document.getElementById('copyBtn');

                btnText.innerText = 'Copied to Clipboard';
                btn.style.background = '#27c93f';
                btnIcon.setAttribute('data-lucide', 'check-circle');
                lucide.createIcons();

                setTimeout(() => {
                    btnText.innerText = 'Copy Code';
                    btn.style.background = 'var(--accent)';
                    btnIcon.setAttribute('data-lucide', 'copy');
                    lucide.createIcons();
                }, 2000);
            });
        }
    </script>
</body>
