            max-width: 600px;
            font-size: clamp(1rem, 2vw, 1.25rem);
            color: var(--text-muted);
            margin: 25px 0;
        }

        .section {
            max-width: 1100px;
            margin: 0 auto;
            padding: 20px 24px 60px 24px;
        }

        .terminal-container {
            max-width: 1000px;
            margin: 40px auto;
            background: var(--code-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0,0,0,0.7);
        }

        .terminal-header {
            background: #0f111a;
            padding: 14px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .terminal-controls { display: flex; gap: 8px; }
        .control { width: 12px; height: 12px; border-radius: 50%; opacity: 0.5; }
        .red { background: #ff5f56; }
        .yellow { background: #ffbd2e; }
        .green { background: #27c93f; }

        .copy-btn {
            background: var(--accent);
            border: none;
            color: white;
            padding: 10px 24px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .copy-btn:hover { background: var(--accent-hover); transform: translateY(-1px); }

        pre {
            margin: 0;
            padding: 30px;
            overflow-x: auto;
            font-family: 'Fira Code', monospace;
            font-size: 13px;
            color: #94a3b8;
            text-align: left;
            line-height: 1.6;
            max-height: 600px;
            overflow-y: auto;
        }

        pre::-webkit-scrollbar { width: 8px; }
        pre::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }

        .cta-button {
            background: #fff;
            color: #000;
            padding: 16px 36px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 16px;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .cta-button:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(255,255,255,0.1); }

        .comment { color: #475569; font-style: italic; }
        .keyword { color: #818cf8; }
        .string { color: #4ade80; }
        .const { color: #f472b6; }
        .func { color: #fbbf24; }

        footer {
            padding: 40px 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 12px;
            border-top: 1px solid var(--border);
            letter-spacing: 1px;
        }
    </style>
</head>
